import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        long product = 1; 
        int i;
        int n = sc.nextInt(); 
        for(i = 1; i <= n; i++){
            product = product * i;
        }
        System.out.print(product);
    }
}
